# ========================================
# SECAPP - Variáveis de Ambiente
# ========================================
# Copie este arquivo para .env.local e preencha com SEUS dados.
# NUNCA compartilhe ou commit o arquivo .env.local!

# ========================================
# SUPABASE
# ========================================
# Obter em: https://supabase.com → Seu Projeto → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# EVOLUTION API
# ========================================
# URL da sua instância na VPS

# Se usar domínio próprio:
EVOLUTION_API_URL=https://api.seudominio.com

# OU se usar IP direto:
# EVOLUTION_API_URL=http://123.456.789.000:8080

# API Key da Evolution (obter no painel da Evolution)
EVOLUTION_API_KEY=sua-api-key-aqui

# Nome da instância do WhatsApp (criada na Evolution)
EVOLUTION_INSTANCE_NAME=secapp

# ========================================
# WHATSAPP
# ========================================
# Seu número para receber as mensagens
# Formato: 55 + DDD + número (apenas dígitos)

WHATSAPP_NUMBER=5511999999999
